# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

# Local test script
/scripts/reset-test-settings.js

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

# Mihomo/Clash core binaries
/cores/

# extra resources (sidecar, files)
/extra

# release & dist output
/release
/dist

# sysproxy build artifacts (built by GitHub Actions)
/tools/sysproxy*.exe

# local build config
electron-builder.local.yml

# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug & logs
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*
*.log

# env files
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# AI / editor generated
.claude/
.playwright-mcp/
.windsurfrules
.vscode/
.config/

# npm cache
.npm/

# Binary executables - should not be in source control
*.exe

# GeoIP databases - download at build time
tools/data/*.mmdb
tools/data/*.dat
tools/data/*.metadb

# Local build/clean scripts
*.bat
*.ps1

# Backup & temp files
*.bak
main_backup.js
package.json.bak

# Large JSON release caches
metacubex_releases.json
vernesong_releases.json

# Windows null device artifact
nul

# Temp fix scripts
fix.js
electron/fix.js

# docs (auto-generated)
/docs/

# *.md except README
/*.md
!README.md
