# See https://help.github.com/articles/ignoring-files/ for more about ignoring files.

nul

# dependencies
/node_modules
/.pnp
.pnp.*
.yarn/*
!.yarn/patches
!.yarn/plugins
!.yarn/releases
!.yarn/versions

/cores/mihomo-windows-amd64.exe
/extra
/release
/dist

# sysproxy build artifacts (built by GitHub Actions)
/tools/sysproxy*.exe

# local build config
electron-builder.local.yml
# testing
/coverage

# next.js
/.next/
/out/

# production
/build

# misc
.DS_Store
*.pem

# debug
npm-debug.log*
yarn-debug.log*
yarn-error.log*
.pnpm-debug.log*

# env files (can opt-in for committing if needed)
.env*

# vercel
.vercel

# typescript
*.tsbuildinfo
next-env.d.ts

# AI generated directories
.claude/
.playwright-mcp/

# AI generated docs (keep README.md)
/*.md
!README.md
/docs/

# Large JSON release caches
metacubex_releases.json
vernesong_releases.json
