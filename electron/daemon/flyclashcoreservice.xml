	<argument>undefined</argument>
	<logmode>rotate</logmode>
	<stoptimeout>30sec</stoptimeout>
	<env name="FLYCAST_SERVICE_CONFIG" value="C:\Users\GtxFury\AppData\Roaming\liberbox\service\service-config.json"/>
	<serviceaccount>
		<domain>NONE</domain>
		<user>LocalSystem</user>
		<password></password>
	</serviceaccount>
	<workingdirectory>F:\code\Liberbox-PC\flycast-ui</workingdirectory>
</service>