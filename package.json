{
  "name": "flyclash-ui",
  "version": "0.2.6",
  "description": "FlyClash Desktop",
  "author": {
    "name": "FlyClash",
    "email": "flyclash@flyclash.com"
  },
  "private": true,
  "main": "electron/main.js",
  "scripts": {
    "dev": "next dev",
    "build": "next build",
    "start": "next start",
    "lint": "next lint",
    "rebuild:native": "electron-rebuild -f -w better-sqlite3",
    "postinstall": "electron-builder install-app-deps",
    "prepare": "node scripts/prepare.mjs",
    "prepare:win": "node scripts/prepare.mjs",
    "prepare:win:x64": "node scripts/prepare.mjs --x64",
    "prepare:win:ia32": "node scripts/prepare.mjs --ia32",
    "prepare:win:arm64": "node scripts/prepare.mjs --arm64",
    "prepare:mac": "node scripts/prepare.mjs",
    "prepare:mac:x64": "node scripts/prepare.mjs --x64",
    "prepare:mac:arm64": "node scripts/prepare.mjs --arm64",
    "prepare:linux": "node scripts/prepare.mjs",
    "prepare:linux:x64": "node scripts/prepare.mjs --x64",
    "prepare:linux:arm64": "node scripts/prepare.mjs --arm64",
    "preelectron:dev": "npm run rebuild:native",
    "electron:dev": "concurrently \"cross-env npm run dev\" \"wait-on http://localhost:3000 && cross-env NODE_ENV=development electron . --js-flags='--expose-gc'\"",
    "electron": "electron . --js-flags='--expose-gc'",
    "electron:build": "npm run prepare:win && next build --no-lint && electron-builder --config electron-builder.local.yml",
    "electron:build:ci": "npm run prepare && next build --no-lint && electron-builder",
    "electron:build:ignore-ts": "npm run prepare:win && set NEXT_TELEMETRY_DISABLED=1 && set NEXT_IGNORE_TYPE_ERROR=1 && next build && electron-builder --config electron-builder.local.yml",
    "electron:build:prod": "npm run prepare:win && set NEXT_TELEMETRY_DISABLED=1 && set NEXT_PUBLIC_BASE_PATH=./ && next build && electron-builder --config electron-builder.local.yml",
    "electron:build:mac": "npm run prepare:mac && next build --no-lint && electron-builder --mac",
    "electron:build:mac:x64": "npm run prepare:mac:x64 && next build --no-lint && electron-builder --mac --x64",
    "electron:build:mac:arm64": "npm run prepare:mac:arm64 && next build --no-lint && electron-builder --mac --arm64",
    "electron:build:mac:universal": "next build --no-lint && npm run prepare:mac:x64 && npm run prepare:mac:arm64 && electron-builder --mac --x64 --arm64",
    "clean": "node clean.js"
  },
  "dependencies": {
    "@dnd-kit/core": "^6.3.1",
    "@dnd-kit/sortable": "^10.0.0",
    "@dnd-kit/utilities": "^3.2.2",
    "@radix-ui/react-alert-dialog": "^1.1.10",
    "@radix-ui/react-avatar": "^1.1.3",
    "@radix-ui/react-checkbox": "^1.1.4",
    "@radix-ui/react-dialog": "^1.1.6",
    "@radix-ui/react-dropdown-menu": "^2.1.6",
    "@radix-ui/react-icons": "^1.3.2",
    "@radix-ui/react-label": "^2.1.2",
    "@radix-ui/react-navigation-menu": "^1.2.5",
    "@radix-ui/react-popover": "^1.1.6",
    "@radix-ui/react-progress": "^1.1.2",
    "@radix-ui/react-radio-group": "^1.3.6",
    "@radix-ui/react-scroll-area": "^1.2.3",
    "@radix-ui/react-separator": "^1.1.2",
    "@radix-ui/react-slot": "^1.1.2",
    "@radix-ui/react-switch": "^1.1.3",
    "@radix-ui/react-tabs": "^1.1.3",
    "@radix-ui/react-toast": "^1.2.6",
    "@radix-ui/react-tooltip": "^1.1.8",
    "@types/js-yaml": "^4.0.9",
    "adm-zip": "^0.5.16",
    "axios": "^1.8.4",
    "better-sqlite3": "^11.8.1",
    "class-variance-authority": "^0.7.1",
    "classnames": "^2.5.1",
    "clsx": "^2.1.1",
    "finalhandler": "^2.1.0",
    "html2canvas": "^1.4.1",
    "http-proxy-agent": "^7.0.2",
    "https-proxy-agent": "^7.0.6",
    "i18next": "25.6.0",
    "i18next-browser-languagedetector": "8.2.0",
    "js-yaml": "^4.1.0",
    "json5": "2.2.3",
    "lucide-react": "^0.487.0",
    "next": "^14.0.4",
    "node-fetch": "^3.3.2",
    "node-windows": "^1.0.0-beta.8",
    "ofetch": "^1.4.1",
    "peggy": "5.0.6",
    "proxy-agent": "^6.5.0",
    "react": "^18.2.0",
    "react-dom": "^18.2.0",
    "react-i18next": "16.2.0",
    "react-intersection-observer": "^9.16.0",
    "react-virtualized-auto-sizer": "^1.0.26",
    "react-virtuoso": "^4.7.5",
    "react-window": "^1.8.11",
    "run": "^1.5.0",
    "serve-static": "^2.2.0",
    "sonner": "^2.0.3",
    "swr": "^2.3.3",
    "tailwind-merge": "^3.2.0",
    "tailwindcss-animate": "^1.0.7",
    "twemoji": "14.0.2",
    "uuid": "13.0.0",
    "webdav": "^5.8.0",
    "ws": "^8.18.1",
    "zustand": "^5.0.3"
  },
  "devDependencies": {
    "@electron/rebuild": "^4.0.1",
    "@tailwindcss/postcss": "^4",
    "@types/node": "^20",
    "@types/react": "^19",
    "@types/react-dom": "^19",
    "@types/react-virtualized-auto-sizer": "^1.0.4",
    "@types/react-window": "^1.8.8",
    "autoprefixer": "^10.4.15",
    "concurrently": "^8.2.2",
    "cross-env": "^7.0.3",
    "electron": "^35.1.4",
    "electron-builder": "^26.0.12",
    "electron-rebuild": "^3.2.9",
    "file-loader": "^6.2.0",
    "postcss": "^8.4.31",
    "ref-napi": "^3.0.3",
    "ref-struct-di": "^1.1.0",
    "tailwindcss": "^3.3.0",
    "typescript": "^5",
    "wait-on": "^8.0.3"
  },
  "optionalDependencies": {
    "dmg-license": "^1.0.11"
  }
}
